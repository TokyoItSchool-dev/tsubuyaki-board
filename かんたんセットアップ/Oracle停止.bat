@echo off
chcp 65001 >nul
rem ============================================================
rem  Oracle を停止します。
rem  作ったデータはそのまま残ります（次回また使えます）。
rem ============================================================

rem --- リポジトリのルート（このフォルダの1つ上）を求める ---
pushd "%~dp0.." & set "REPO=%CD%" & popd

echo.
echo Oracle を停止しています...
echo.

wsl -d Ubuntu-22.04 --cd "%REPO%" -- bash scripts/stop-oracle.sh

if errorlevel 1 (
echo.
echo ============================================================
echo  [失敗] エラーが発生しました。上のメッセージをご確認ください。
echo  解決しない場合は、この画面をそのまま講師にお見せください。
echo ============================================================
echo.
pause
exit /b 1
)

echo.
echo ============================================================
echo  停止しました。データはそのまま残っています。
echo ============================================================
echo.
pause
